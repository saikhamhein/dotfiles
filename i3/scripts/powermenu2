#!/usr/bin/env bash
#
# options="’ĆŻ Lock\n’åå Suspend\n’éŗ Logout\n’Ć× Reboot\n’Ćæ Shutdown"
options="’ĆŻ \n’åå \n’éŗ \n’Ć× \n’Ćæ "

chosen=$(echo -e "$options" | rofi -dmenu -i -p "Power" -theme ~/.config/rofi/powermenu2.rasi)

case "$chosen" in
"’ĆŻ Lock") ~/.config/i3/scripts/blur-lock ;;
"’åå Suspend") systemctl suspend ;;
"’éŗ Logout") i3-msg exit ;;
"’Ć× Reboot") systemctl reboot ;;
"’Ćæ Shutdown") systemctl poweroff ;;
esac
